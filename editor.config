root = true

[*]
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
charset = utf-8
indent_style = space
indent_size = 4

[{*.json,*.html,*.css,*.svg}]
indent_size = 2

[{*.yml,*.yaml}]
indent_size = 2

[{*.md,*.txt}]
trim_trailing_whitespace = false

[Makefile]
indent_style = tab